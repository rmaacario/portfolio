---
import { writing } from "../data/content";
import Icon from "./Icon.astro";
const base = import.meta.env.BASE_URL;
---

<section class="section writing" id="writing">
  <div class="container">
    <div class="section-head reveal">
      <span class="section-num">05</span>
      <h2 class="section-title">Documentation, end to end</h2>
    </div>

    <div class="w-lead reveal">
      <span class="w-eyebrow mono">{writing.eyebrow}</span>
      <p class="w-lead-text">{writing.lead}</p>
      <div class="w-lead-links">
        <a class="btn btn-primary" href={writing.hubUrl} target="_blank" rel="noopener">
          <Icon name="book" size={17} /> Browse the docs
        </a>
        <a class="btn btn-ghost" href={writing.tutorialsUrl} target="_blank" rel="noopener">
          AI Tutorials <Icon name="external" size={15} />
        </a>
        <a class="btn btn-ghost" href={writing.newsUrl} target="_blank" rel="noopener">
          AI News <Icon name="external" size={15} />
        </a>
      </div>
    </div>

    <p class="w-strap reveal">Three documentation platforms I design, build, and write — each with its own product identity.</p>

    <div class="w-sites">
      {
        writing.sites.map((s, i) => (
          <a
            class="w-site reveal"
            data-delay={`${i * 80}ms`}
            href={s.href}
            target="_blank"
            rel="noopener"
            aria-label={`Visit ${s.name} documentation`}
          >
            <span class="w-chrome">
              <span class="w-dot" /><span class="w-dot" /><span class="w-dot" />
              <span class="w-url mono">{s.host}</span>
            </span>

            <span class="w-shot">
              <img
                src={`${base}covers/site-${s.id}.png`}
                alt={`${s.name} documentation homepage`}
                loading="lazy"
              />
            </span>

            <span class="w-site-foot">
              <span class="w-site-name">
                {s.name}
                <Icon name="external" size={14} />
              </span>
              <span class="w-site-desc">{s.desc}</span>
            </span>
          </a>
        ))
      }
    </div>

    <p class="w-strap reveal">A few highlights — hands-on tutorials &amp; a newsletter, every guide run from scratch on a real box.</p>

    <div class="w-grid">
      {
        writing.series.map((s, i) => (
          <div class="w-card reveal" data-delay={`${i * 70}ms`}>
            <div class="w-card-head">
              <span class="w-kind mono">{s.kind}</span>
              <h3 class="w-series">{s.name}</h3>
              <p class="w-blurb">{s.blurb}</p>
            </div>
            <ul class="w-articles">
              {s.articles.map((a) => (
                <li>
                  <a class="w-article" href={a.href} target="_blank" rel="noopener">
                    <span class="w-meta">
                      {a.part && <span class="w-part mono">{a.part}</span>}
                      {a.level && <span class={`w-level w-level-${a.level.toLowerCase()}`}>{a.level}</span>}
                      {a.upcoming && <span class="w-soon mono">Soon</span>}
                      {a.read && <span class="w-read mono">{a.read}</span>}
                    </span>
                    <span class="w-a-title">
                      {a.title}
                      <Icon name="external" size={14} />
                    </span>
                    <span class="w-a-blurb">{a.blurb}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="w-more reveal">
      <a class="btn btn-ghost" href={writing.tutorialsUrl} target="_blank" rel="noopener">
        Read all tutorials &amp; AI News <Icon name="arrow" size={16} />
      </a>
    </div>
  </div>
</section>

<style>
  .w-lead {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3.5vw, 2.5rem);
    margin-bottom: 1.6rem;
    box-shadow: var(--shadow);
  }
  .w-eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent-text);
  }
  .w-lead-text {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 2.1vw, 1.55rem);
    line-height: 1.45;
    margin-top: 0.8rem;
    letter-spacing: -0.015em;
    max-width: 62ch;
  }
  .w-lead-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.6rem;
  }

  .w-strap {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 2.2rem 0 1rem;
  }

  /* --- Documentation-site gallery --- */
  .w-sites {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.1rem;
  }
  .w-site {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.3s var(--ease), border-color 0.3s var(--ease),
      box-shadow 0.3s var(--ease);
  }
  .w-site:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }
  .w-chrome {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.7rem;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .w-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
  }
  .w-dot:nth-child(1) { background: #ef7d6a; }
  .w-dot:nth-child(2) { background: #f0b429; }
  .w-dot:nth-child(3) { background: #57c78e; }
  .w-url {
    margin-left: 0.5rem;
    font-size: 0.68rem;
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Preview canvas — real site screenshot, framed to the hero */
  .w-shot {
    display: block;
    height: 188px;
    overflow: hidden;
    background: var(--bg);
  }
  .w-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.5s var(--ease);
  }
  .w-site:hover .w-shot img {
    transform: scale(1.03);
  }

  .w-site-foot {
    padding: 0.95rem 1.1rem 1.1rem;
    border-top: 1px solid var(--border);
  }
  .w-site-name {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 1rem;
    color: var(--text);
  }
  .w-site-name :global(svg) { color: var(--text-muted); }
  .w-site-desc {
    display: block;
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
    margin-top: 0.3rem;
  }

  /* --- Tutorials + newsletter --- */
  .w-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.1rem;
  }
  .w-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.6rem;
    transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
  }
  .w-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
  }
  .w-kind {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--accent-text);
  }
  .w-series {
    font-size: 1.25rem;
    margin-top: 0.5rem;
  }
  .w-blurb {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-top: 0.6rem;
    line-height: 1.6;
  }
  .w-articles {
    list-style: none;
    margin: 1.2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .w-article {
    display: block;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease),
      background 0.25s var(--ease);
  }
  .w-article:hover {
    transform: translateX(3px);
    border-color: var(--accent);
    background: var(--bg);
  }
  .w-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.4rem;
  }
  .w-part {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-text);
  }
  .w-level {
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.12rem 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--text-muted);
  }
  .w-level-beginner {
    color: var(--accent-text);
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
  }
  .w-soon {
    font-size: 0.66rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.12rem 0.45rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    color: var(--accent-text);
  }
  .w-read {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-left: auto;
  }
  .w-a-title {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 0.97rem;
    line-height: 1.4;
    color: var(--text);
  }
  .w-a-title :global(svg) {
    flex: none;
    margin-top: 0.2rem;
    color: var(--text-muted);
  }
  .w-a-blurb {
    display: block;
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.55;
    margin-top: 0.35rem;
  }

  .w-more {
    display: flex;
    justify-content: center;
    margin-top: 1.6rem;
  }

  @media (max-width: 900px) {
    .w-sites {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 820px) {
    .w-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
