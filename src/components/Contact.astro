---
import { site, socials } from "../data/content";
import Icon from "./Icon.astro";
import SymbolMark from "./SymbolMark.astro";
---

<section class="section contact" id="contact">
  <div class="contact-symbol contact-symbol-l"><SymbolMark variant="zigzag" /></div>
  <div class="contact-symbol contact-symbol-r"><SymbolMark variant="diamond" /></div>
  <div class="container contact-inner reveal">
    <p class="eyebrow">Let's talk</p>
    <h2 class="contact-head">
      Building something with language &amp; AI?
    </h2>
    <p class="contact-sub">
      I'm open to collaborations on NLP, LLM evaluation, RAG systems, and
      low-resource language technology. The fastest way to reach me is email.
    </p>

    <a class="btn btn-primary contact-btn" href={`mailto:${site.email}`}>
      <Icon name="mail" size={18} /> {site.email}
    </a>

    <div class="contact-socials">
      {
        socials
          .filter((s) => s.icon !== "mail")
          .map((s) => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
              <Icon name={s.icon} size={20} />
              <span>{s.label}</span>
            </a>
          ))
      }
    </div>
  </div>
</section>

<style>
  .contact {
    text-align: center;
    padding-block: clamp(5rem, 11vw, 9rem);
    position: relative;
    overflow: hidden;
  }
  .contact-symbol {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: clamp(130px, 16vw, 190px);
    opacity: 0.55;
    pointer-events: none;
  }
  .contact-symbol-l {
    left: clamp(0.5rem, 4vw, 4rem);
  }
  .contact-symbol-r {
    right: clamp(0.5rem, 4vw, 4rem);
  }
  @media (max-width: 820px) {
    .contact-symbol {
      display: none;
    }
  }
  .contact-inner {
    max-width: 640px;
    margin-inline: auto;
  }
  .contact-head {
    font-size: clamp(2rem, 5.5vw, 3.4rem);
    margin: 0.8rem 0 0;
    line-height: 1.08;
  }
  .contact-sub {
    color: var(--text-muted);
    font-size: 1.08rem;
    margin: 1.4rem auto 0;
    max-width: 48ch;
    line-height: 1.6;
  }
  .contact-btn {
    margin-top: 2.2rem;
    font-size: 1.05rem;
    padding: 0.9rem 1.6rem;
  }
  .contact-socials {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.6rem 1.8rem;
    margin-top: 2.5rem;
  }
  .contact-socials a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.95rem;
    transition: color 0.2s var(--ease);
  }
  .contact-socials a:hover {
    color: var(--accent-text);
  }
</style>
