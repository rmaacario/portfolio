---
import { techStack } from "../data/content";
import SymbolMark from "./SymbolMark.astro";
const base = import.meta.env.BASE_URL;
---

<section class="section skills" id="skills">
  <div class="skills-symbol"><SymbolMark variant="diamond" /></div>
  <div class="container">
    <div class="section-head reveal">
      <span class="section-num">05</span>
      <h2 class="section-title">Skills &amp; tools</h2>
    </div>

    <div class="groups">
      {
        techStack.map((g, gi) => (
          <div class="group reveal" data-delay={`${gi * 70}ms`}>
            <h3 class="group-label mono">{g.group}</h3>
            <div class="wall">
              {g.items.map((t) => (
                <div class={`logo ${t.dark ? "is-dark" : ""}`} title={t.name}>
                  <img
                    src={`${base}logos/${t.slug}.svg`}
                    alt={t.name}
                    width="40"
                    height="40"
                    loading="lazy"
                  />
                  <span class="logo-name">{t.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills {
    position: relative;
    overflow: hidden;
  }
  .skills-symbol {
    position: absolute;
    top: 12%;
    left: clamp(0.5rem, 1.5vw, 1.5rem);
    height: clamp(110px, 13vw, 160px);
    opacity: 0.34;
    pointer-events: none;
    z-index: 0;
  }
  .skills .container {
    position: relative;
    z-index: 1;
  }
  @media (max-width: 1100px) {
    .skills-symbol {
      display: none;
    }
  }
  .groups {
    display: flex;
    flex-direction: column;
    gap: clamp(2.5rem, 5vw, 3.5rem);
  }
  .group-label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--teal);
    margin-bottom: 1.8rem;
  }
  .wall {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.8rem, 4vw, 3.2rem) clamp(2rem, 5vw, 4rem);
    align-items: flex-start;
  }
  .logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
    width: 64px;
    text-align: center;
  }
  .logo img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    transition: transform 0.25s var(--ease), filter 0.25s var(--ease);
  }
  .logo:hover img {
    transform: translateY(-5px) scale(1.08);
  }
  /* Near-black logos: lighten in dark mode so they stay legible with no backing. */
  :root[data-theme="dark"] .logo.is-dark img {
    filter: brightness(0) invert(0.82);
  }
  :root[data-theme="dark"] .logo.is-dark:hover img {
    filter: brightness(0) invert(1);
  }
  .logo-name {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.25;
    transition: color 0.2s var(--ease);
  }
  .logo:hover .logo-name {
    color: var(--accent-text);
  }
</style>
