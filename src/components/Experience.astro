---
import { experience, education, site } from "../data/content";
import SymbolMark from "./SymbolMark.astro";
import Avatar from "./Avatar.astro";
---

<section class="section exp" id="experience">
  <div class="exp-symbol"><SymbolMark variant="diamond" /></div>
  <div class="container">
    <div class="section-head reveal">
      <span class="section-num">03</span>
      <h2 class="section-title">Experience</h2>
    </div>

    <div class="about reveal" data-delay="60ms">
      <Avatar size={148} radius="16px" class="about-photo" />
      <p class="lead">{site.intro}</p>
    </div>

    <div class="exp-grid">
      <div class="timeline">
        {
          experience.map((e, i) => (
            <article class="tl-item reveal" data-delay={`${i * 70}ms`}>
              <div class="tl-marker" />
              <div class="tl-body">
                <div class="tl-head">
                  <h3 class="tl-role">{e.role}</h3>
                  <span class="tl-period mono">{e.period}</span>
                </div>
                <p class="tl-company">
                  {e.company} <span class="tl-loc">· {e.location}</span>
                </p>
                <ul class="tl-points">
                  {e.points.map((p) => (
                    <li>{p}</li>
                  ))}
                </ul>
                <div class="tl-stack">
                  {e.stack.map((s) => (
                    <span class="tag">{s}</span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <aside class="edu reveal" data-delay="120ms">
        <h3 class="edu-title">Education</h3>
        {
          education.map((ed) => (
            <div class="edu-item">
              <p class="edu-degree">{ed.degree}</p>
              <p class="edu-school">{ed.school}</p>
              <p class="edu-period mono">{ed.period}</p>
              <p class="edu-detail">{ed.detail}</p>
            </div>
          ))
        }
        <div class="edu-langs">
          <h4 class="edu-langs-title mono">Languages</h4>
          {
            site.languages.map((l) => (
              <div class="lang-row">
                <span>{l.name}</span>
                <span class="lang-level mono">{l.level}</span>
              </div>
            ))
          }
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .exp {
    position: relative;
    overflow: hidden;
  }
  .exp-symbol {
    position: absolute;
    top: 18%;
    right: clamp(0.5rem, 2vw, 2rem);
    height: clamp(120px, 14vw, 170px);
    opacity: 0.4;
    pointer-events: none;
    z-index: 0;
  }
  .exp .container {
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) {
    .exp-symbol {
      display: none;
    }
  }
  .about {
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .lead {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.5vw, 1.7rem);
    line-height: 1.45;
    max-width: 44ch;
    color: var(--text);
    letter-spacing: -0.015em;
  }
  @media (max-width: 680px) {
    .about {
      flex-direction: column;
      align-items: flex-start;
    }
  }
  .exp-grid {
    display: grid;
    grid-template-columns: 1.6fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .timeline {
    position: relative;
  }
  .tl-item {
    position: relative;
    padding-left: 2rem;
    padding-bottom: 2.5rem;
  }
  .tl-item:last-child {
    padding-bottom: 0;
  }
  .tl-item::before {
    content: "";
    position: absolute;
    left: 5px;
    top: 8px;
    bottom: -8px;
    width: 1.5px;
    background: var(--border-strong);
  }
  .tl-item:last-child::before {
    display: none;
  }
  .tl-marker {
    position: absolute;
    left: 0;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--bg);
    border: 2.5px solid var(--accent);
    z-index: 1;
  }
  .tl-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .tl-role {
    font-size: 1.25rem;
  }
  .tl-period {
    font-size: 0.8rem;
    color: var(--text-faint);
    flex: 0 0 auto;
  }
  .tl-company {
    color: var(--accent-text);
    font-weight: 500;
    margin-top: 0.2rem;
  }
  .tl-loc {
    color: var(--text-faint);
    font-weight: 400;
  }
  .tl-points {
    list-style: none;
    margin-top: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .tl-points li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--text-muted);
    font-size: 0.96rem;
    line-height: 1.55;
  }
  .tl-points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.6;
  }
  .tl-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .edu {
    position: sticky;
    top: 90px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.6rem;
  }
  .edu-title {
    font-size: 1.2rem;
    margin-bottom: 1.2rem;
  }
  .edu-item {
    padding-bottom: 1.2rem;
    margin-bottom: 1.2rem;
    border-bottom: 1px solid var(--border);
  }
  .edu-degree {
    font-weight: 500;
  }
  .edu-school {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-top: 0.1rem;
  }
  .edu-period {
    color: var(--text-faint);
    font-size: 0.78rem;
    margin-top: 0.3rem;
  }
  .edu-detail {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.5rem;
    line-height: 1.5;
  }
  .edu-langs-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    margin-bottom: 0.7rem;
  }
  .lang-row {
    display: flex;
    justify-content: space-between;
    padding: 0.35rem 0;
    font-size: 0.92rem;
  }
  .lang-level {
    color: var(--accent-text);
    font-size: 0.8rem;
  }

  @media (max-width: 820px) {
    .exp-grid {
      grid-template-columns: 1fr;
    }
    .edu {
      position: static;
    }
  }
</style>
