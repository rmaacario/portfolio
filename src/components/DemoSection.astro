---
import ChatBot from "./ChatBot.tsx";
import ChatMascot from "./ChatMascot.astro";
import Icon from "./Icon.astro";
---

<section class="section demo" id="demo">
  <div class="container">
    <div class="section-head reveal">
      <span class="section-num">02</span>
      <h2 class="section-title">Ask my portfolio anything</h2>
    </div>

    <div class="demo-card reveal" data-delay="80ms">
      <div class="demo-head">
        <div class="demo-intro">
          <span class="demo-badge mono">
            <Icon name="spark" size={14} /> live <strong>RAG</strong> chatbot · grounded answers
          </span>
          <p>
            This is a working <strong>retrieval-augmented chatbot</strong> — the same
            kind I ship in production. A transformer embedding model loads
            <em>in your browser</em> and retrieves the most relevant pieces of my
            background; a language model then answers your question grounded in
            exactly those pieces. Expand <em>“sources”</em> under any answer to see
            what it was built on.
          </p>
        </div>
        <div class="demo-mascot">
          <span class="mascot-hello">Puranga ára! 👋<br class="br-m" /> Ask me anything 🌿</span>
          <ChatMascot />
        </div>
      </div>
      <ChatBot client:visible />
    </div>
  </div>
</section>

<style>
  .demo-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(1.4rem, 3.5vw, 2.4rem);
    box-shadow: var(--shadow);
  }
  .demo-head {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.5rem);
    margin-bottom: 1.6rem;
  }
  .demo-intro {
    flex: 1 1 auto;
  }
  .demo-mascot {
    flex: 0 0 auto;
    position: relative;
    display: grid;
    place-items: center;
  }
  /* Friendly greeting bubble that pops in and gently floats by the mascot.
     Desktop: sits to the LEFT of the mascot (tail bottom-right). */
  .mascot-hello {
    position: absolute;
    top: 6px;
    right: 100%;
    margin-right: -2.6rem;
    white-space: nowrap;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 0.86rem;
    font-weight: 500;
    padding: 0.5rem 0.85rem;
    border-radius: 14px 14px 4px 14px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    transform-origin: bottom right;
    animation: hello-pop 0.5s var(--ease) 0.6s both,
      hello-float 3.6s ease-in-out 1.1s infinite;
  }
  /* line break inside the bubble only kicks in on small screens */
  .br-m {
    display: none;
  }
  .mascot-hello::after {
    content: "";
    position: absolute;
    right: 16px;
    bottom: -7px;
    width: 12px;
    height: 12px;
    background: var(--surface);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transform: rotate(45deg);
  }
  @keyframes hello-pop {
    from { opacity: 0; transform: scale(0.7) translateY(6px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes hello-float {
    0%, 100% { translate: 0 0; }
    50% { translate: 0 -5px; }
  }
  /* Mobile: mascot is left-aligned above the copy — put the bubble in the open
     space to its RIGHT, on two lines (tail bottom-left). */
  @media (max-width: 620px) {
    .mascot-hello {
      left: 100%;
      right: auto;
      margin-right: 0;
      margin-left: 0.6rem;
      top: 18px;
      white-space: nowrap;
      font-size: 0.84rem;
      line-height: 1.45;
      text-align: left;
      border-radius: 14px 14px 14px 4px;
      transform-origin: bottom left;
    }
    .br-m {
      display: inline;
    }
    .mascot-hello::after {
      right: auto;
      left: 16px;
      border-right: none;
      border-bottom: 1px solid var(--border);
      border-left: 1px solid var(--border);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .mascot-hello { animation: hello-pop 0.01s both; }
  }
  @media (max-width: 620px) {
    .demo-head {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 1rem;
    }
  }
  .demo-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-text);
    background: var(--accent-soft);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }
  .demo-intro p {
    max-width: 60ch;
    color: var(--text-muted);
    font-size: 1.02rem;
  }
  .demo-intro strong {
    color: var(--text);
    font-weight: 500;
  }
  .demo-intro em {
    font-style: italic;
    color: var(--accent-text);
  }
</style>
