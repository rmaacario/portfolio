---
import { site } from "../data/content";
interface Props {
  size?: number;
  radius?: string;
  class?: string;
}
const { size = 200, radius = "18px", class: cls = "" } = Astro.props;
const base = import.meta.env.BASE_URL;
const src = `${base}${site.photo}`;
---

<div class={`avatar ${cls}`} style={`--sz:${size}px; --avatar-radius:${radius}`}>
  <img
    src={src}
    alt={site.name}
    width={size}
    height={size}
    loading="eager"
    onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';"
  />
  <span class="avatar-fallback" style="display:none" aria-hidden="true">
    {site.initials}
  </span>
</div>

<style>
  .avatar {
    width: var(--sz);
    height: var(--sz);
    position: relative;
    border-radius: var(--avatar-radius, 18px);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface-2);
    flex: 0 0 auto;
  }
  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 22%;
  }
  .avatar-fallback {
    position: absolute;
    inset: 0;
    place-items: center;
    font-family: var(--font-display);
    font-size: calc(var(--sz) * 0.34);
    font-weight: 500;
    color: var(--accent-text);
    background: var(--accent-soft);
  }
</style>
